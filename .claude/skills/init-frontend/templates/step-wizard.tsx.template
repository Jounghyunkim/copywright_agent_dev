// Template: Step-Based Wizard UX
// Customize STEP_LABELS, INPUT_FIELDS, and step-specific rendering for your domain.

import { useEffect, useRef, useState } from 'react'
import { Link, useSearchParams } from 'react-router-dom'
import { apiClient } from '@/shared/api/client'
import { Button } from '@/shared/ui/button'
import { Card } from '@/shared/ui/card'

// === CUSTOMIZE THESE ===
type Step = 1 | 2 | 3 | 4  // Add more steps as needed
const STEP_LABELS = ['입력', 'AI 처리', '선택', '결과 확인']
const HUMAN_STEPS = new Set<Step>([1, 3, 4])
// === END CUSTOMIZE ===

export function NewWorkflowPage() {
  const [searchParams] = useSearchParams()
  const [step, setStep] = useState<Step>(1)
  const [caseId, setCaseId] = useState<string | null>(null)
  const [error, setError] = useState('')
  const pollRef = useRef<ReturnType<typeof setInterval> | null>(null)
  const seenCountRef = useRef(0)
  const resumedRef = useRef(false)

  // Resume from query params
  useEffect(() => {
    if (resumedRef.current) return
    const qCaseId = searchParams.get('caseId')
    const qStep = Number(searchParams.get('step') || 0)
    if (!qCaseId || !qStep) return
    resumedRef.current = true
    setCaseId(qCaseId)
    setStep(qStep as Step)
    // If AI step, start polling
    if (!HUMAN_STEPS.has(qStep as Step)) {
      startPolling(qCaseId)
    }
  }, [searchParams])

  // Cleanup
  useEffect(() => () => { if (pollRef.current) clearInterval(pollRef.current) }, [])

  // Polling with baseline tracking
  const startPolling = (id: string) => {
    if (pollRef.current) clearInterval(pollRef.current)
    seenCountRef.current = 0
    apiClient.get<{ items: unknown[] }>(`/cases/${id}/timeline`).then(res => {
      seenCountRef.current = res.items.length
    }).catch(() => {})

    pollRef.current = setInterval(async () => {
      try {
        const res = await apiClient.get<{ items: { event_type: string; payload: Record<string, unknown> }[] }>(`/cases/${id}/timeline`)
        const allItems = res.items ?? []
        const newItems = allItems.slice(seenCountRef.current)
        seenCountRef.current = allItems.length

        for (const ev of newItems) {
          // === CUSTOMIZE: Add your event handlers here ===
          // if (ev.event_type === 'YOUR_EVENT') { setStep(nextStep) }
        }
      } catch { /* ignore */ }
    }, 1500)
  }

  return (
    <div style={{ maxWidth: 900, margin: '0 auto' }}>
      {/* Step Progress Bar */}
      <div style={{
        background: 'var(--color-surface, #fff)',
        borderRadius: 14, border: '1px solid var(--color-border)',
        padding: '12px 8px', marginBottom: 16,
      }}>
        <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
          {STEP_LABELS.map((label, i) => {
            const s = (i + 1) as Step
            const done = step > s
            const active = step === s
            return (
              <div key={i} style={{ display: 'flex', alignItems: 'center' }}>
                <div style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', width: 90 }}>
                  <div style={{
                    width: 28, height: 28, borderRadius: '50%',
                    background: done ? '#22c55e' : active ? '#c4314b' : '#e5e7eb',
                    color: done || active ? '#fff' : '#9ca3af',
                    display: 'flex', alignItems: 'center', justifyContent: 'center',
                    fontSize: 12, fontWeight: 700,
                  }}>
                    {done ? '✓' : s}
                  </div>
                  <span style={{ fontSize: 11, marginTop: 4, fontWeight: active ? 700 : 400 }}>
                    {HUMAN_STEPS.has(s) ? '👤 ' : '🤖 '}{label}
                  </span>
                </div>
                {i < STEP_LABELS.length - 1 && (
                  <div style={{ width: 24, height: 2, background: done ? '#22c55e' : '#e5e7eb', marginBottom: 18 }} />
                )}
              </div>
            )
          })}
        </div>
      </div>

      {error && <div style={{ padding: '8px 12px', background: '#fef2f2', borderRadius: 8, color: '#b91c1c', fontSize: 13, marginBottom: 12 }}>{error}</div>}

      {/* === CUSTOMIZE: Add step-specific rendering here === */}
      {step === 1 && <Card><p>Step 1: Input form goes here</p></Card>}
      {step === 2 && <Card><p>Step 2: AI processing animation goes here</p></Card>}
      {step === 3 && <Card><p>Step 3: Selection UI goes here</p></Card>}
      {step === 4 && <Card><p>Step 4: Results display goes here</p></Card>}
    </div>
  )
}
