// Template: AI Step Component
// Copy and customize for your new AI processing step.

// Add this block inside the step rendering area of new-workflow-page.tsx:

{step === N && (
  <div style={{ display: 'grid', gap: 16 }}>
    {/* Animation area */}
    <div style={{
      background: 'linear-gradient(180deg, #0d0d1a, #1a1a2e, #0f3460)',
      borderRadius: 20, padding: '32px 24px',
      minHeight: aiStepDone ? 120 : 'calc(100vh - 220px)',
      display: 'flex', flexDirection: 'column',
      alignItems: 'center', justifyContent: 'center', gap: 20,
      transition: 'min-height 0.5s ease',
    }}>
      {!aiStepDone ? (
        <>
          {/* Progress ring */}
          <div style={{ position: 'relative', width: 100, height: 100 }}>
            <svg width={100} height={100} style={{ transform: 'rotate(-90deg)' }}>
              <circle cx={50} cy={50} r={42} fill="none" stroke="rgba(255,255,255,0.08)" strokeWidth={5} />
              <circle cx={50} cy={50} r={42} fill="none" stroke="#c4314b" strokeWidth={5}
                strokeDasharray={264} strokeDashoffset={264 - (264 * progressPct) / 100}
                strokeLinecap="round" style={{ transition: 'stroke-dashoffset 0.5s' }} />
            </svg>
            <div style={{
              position: 'absolute', inset: 0,
              display: 'flex', alignItems: 'center', justifyContent: 'center',
              fontSize: 24, fontWeight: 800, color: '#fff',
            }}>
              {progressPct}%
            </div>
          </div>
          <p style={{ color: 'rgba(255,255,255,0.6)', fontSize: 14 }}>
            {{PROCESSING_MESSAGE}}
          </p>
        </>
      ) : (
        <p style={{ color: '#fff', fontSize: 16, fontWeight: 700 }}>
          ✅ {{COMPLETION_MESSAGE}}
        </p>
      )}
    </div>

    {/* Results (shown when done) */}
    {aiStepDone && (
      <Card style={{ display: 'grid', gap: 10 }}>
        <h3 style={{ margin: 0 }}>처리 결과</h3>
        {/* === Add your result rendering here === */}
        <Button onClick={() => setStep(N + 1)}>
          확인 완료, 다음으로
        </Button>
      </Card>
    )}
  </div>
)}
