from __future__ import annotations
import re

# Skills always included in evaluation
BASE_REQUIRED = [
    # "your-core-skill-1",
    # "your-core-skill-2",
]

# Skills excluded from evaluation (orchestration, translation, etc.)
EXCLUDED_SKILLS = frozenset([
    # "orchestration-skill",
    # "translation-only-skill",
])

# Category → candidate skills mapping
CATEGORY_CANDIDATES: dict[str, list[str]] = {
    # "generation": ["skill-a", "skill-b"],
    # "validation": ["skill-c", "skill-d"],
    # "quality": ["skill-e"],
}

# Keyword patterns in objective/constraints → tags to match
_CAMPAIGN_TAG_RULES: list[tuple[list[str], list[str]]] = [
    # ([r"keyword1", r"keyword2"], ["tag1", "tag2"]),
]


def _contains(text: str, patterns: list[str]) -> bool:
    return any(re.search(p, text, re.I) for p in patterns)


def apply_routing_policy(
    *,
    catalog_names: set[str],
    candidate_skills: list[str],
    objective: str,
    constraints: list[str],
    max_skills: int,
) -> list[str]:
    text = f"{objective} {' '.join(constraints)}".lower()
    eligible = catalog_names - EXCLUDED_SKILLS
    selected: list[str] = []

    def add(skill: str) -> None:
        if skill in eligible and skill not in selected:
            selected.append(skill)

    # 1) Base required
    for s in BASE_REQUIRED:
        add(s)

    # 2) LLM candidates
    for s in candidate_skills:
        add(s)

    # 3) Trigger-based additions
    for patterns, tags in _CAMPAIGN_TAG_RULES:
        if _contains(text, patterns):
            # Add skills matching these tags
            pass

    # 4) Category coverage
    for category in CATEGORY_CANDIDATES:
        if not any(s in selected for s in CATEGORY_CANDIDATES[category]):
            for s in CATEGORY_CANDIDATES[category]:
                if s in eligible:
                    add(s)
                    break

    # 5) Include remaining eligible
    for s in sorted(eligible):
        add(s)

    # 6) Budget cap
    if max_skills > 0 and len(selected) > max_skills:
        selected = selected[:max_skills]

    return selected
