class ApprovalService:
    def __init__(self, repo: ApprovalRepository) -> None:
        self.repo = repo

    async def apply_decision(
        self,
        approval_id: uuid.UUID,
        decision: str,
        decided_by: str,
        payload: dict,
        comment: str,
    ):
        approval = self.repo.get_approval(approval_id)
        if approval is None:
            return None

        # Validate required fields
        if decision == "approve":
            missing_fields = approval.context.get("missing_fields", []) if isinstance(approval.context, dict) else []
            unresolved = [f for f in missing_fields if not payload.get(f)]
            if unresolved:
                raise ValueError(f"missing_required_inputs: {', '.join(unresolved)}")

        updated = self.repo.decide(
            approval=approval, decision=decision,
            decided_by=decided_by, payload=payload, comment=comment,
        )

        # Route to handler based on approval_type
        if decision == "approve":
            # Run heavy processing in background thread to avoid blocking event loop
            if updated.approval_type == "initial_review":
                await asyncio.to_thread(self._handle_initial_review, updated, approval, comment)
            elif updated.approval_type == "selection":
                await asyncio.to_thread(self._handle_selection, updated, payload, comment)
            # ADD MORE approval_type HANDLERS HERE

        return updated

