# Azure OpenAI Service Credentials (for Chat/Completion LLM)
AZURE_OPENAI_API_KEY=your_api_key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_MODEL=your_chat_deployment_name
 
# Azure OpenAI Service Credentials (for Embedding LLM)
EMBEDDING_DEPLOYMENT=your_embedding_deployment_name
EMBEDDING_ENDPOINT=https://your-resource.openai.azure.com/

# Tavily Search API (for web search in Market Analyst)
TAVILY_API_KEY=tvly-your_tavily_api_key

# PostgreSQL Database
DATABASE_URL=postgresql+asyncpg://your_user:your_password@localhost:5432/copywriting_agent_db

# Redis (Session Store)
REDIS_URL=redis://localhost:6379/0

# LDAP Authentication
LDAP_URL=ldaps://lgesaads03.lge.net
LDAP_BASE_DN=dc=lge,dc=net
LDAP_UPN_DOMAIN=lge.com

# Auth
AUTH_SESSION_TTL_MINUTES=30
AUTH_SESSION_ABSOLUTE_TTL_HOURS=12
AUTH_ENV=dev

# Admin Bootstrap (comma-separated user IDs for initial admin seeding)
INITIAL_ADMIN_USER_IDS=jounghyun.kim

# LLM rate limiting (Azure OpenAI 429 mitigation)
# LLM_MAX_CONCURRENCY: 동시 호출 상한 (낮을수록 안전, 높을수록 빠름)
# LLM_RETRY_MAX_ATTEMPTS: 재시도 포함 총 시도 횟수
# LLM_RETRY_BASE_SECONDS: 초기 백오프 (2^(n-1) × base × ±30% jitter)
# LLM_RETRY_MAX_SECONDS: 백오프 상한 (초)
LLM_MAX_CONCURRENCY=4
LLM_RETRY_MAX_ATTEMPTS=4
LLM_RETRY_BASE_SECONDS=1.0
LLM_RETRY_MAX_SECONDS=30.0
